{
  "name": "grok-desktop",
  "version": "1.0.0",
  "description": "Grok Build Desktop — multi-agent command center for SuperGrok / X Premium+",
  "main": "dist-electron/main/index.js",
  "author": "xAI Community",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "electron:dev": "npm run build:electron && concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && GROK_DESKTOP_DEV=1 VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder --mac --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "install:local": "node scripts/install-local.mjs",
    "dist:install": "npm run dist:mac && npm run install:local",
    "verify:launch": "node scripts/bootstrap-shell.mjs launch-1 && node scripts/bootstrap-shell.mjs launch-2",
    "verify:acp": "node scripts/acp-smoke.mjs",
    "verify:structure": "node scripts/structural-audit.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "ai.x.grok.desktop",
    "productName": "Grok Desktop",
    "icon": "resources/icons/icon.icns",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "win": {
      "icon": "resources/icons/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "resources/icons/icon.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "engines": {
    "node": ">=20"
  }
}
